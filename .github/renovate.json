{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": ["config:recommended"],
	"nix": {
		"enabled": true
	},
	"commitMessagePrefix": "📦 ",
	"automerge": true,
	"automergeSchedule": ["before 6am"],
	"labels": ["dependencies", "renovate"],
	"timezone": "Asia/Tokyo",
	"lockFileMaintenance": {
		"enabled": true,
		"schedule": ["before 6am"]
	},
	"vulnerabilityAlerts": {
		"enabled": true,
		"labels": ["security"],
		"schedule": ["at any time"]
	},
	"packageRules": [
		{
			"matchManagers": ["nix"],
			"groupName": "nix flake inputs",
			"commitMessageSuffix": "(flake)"
		},
		{
			"matchManagers": ["github-actions"],
			"automerge": false,
			"commitMessageSuffix": "(actions)"
		}
	]
}
